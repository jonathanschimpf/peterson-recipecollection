{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "es2020",
		"module": "esnext",
		"moduleResolution": "node",
		"baseUrl": ".",
		"paths": {
			"$lib": [
				"src/lib"
			],
			"$lib/*": [
				"src/lib/*"
			],
			"*": [
				"src/types/*"
			]
		}
	},
	"include": [
		"src"
	]
}